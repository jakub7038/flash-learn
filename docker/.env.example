# ================================
# FlashLearn — Environment Variables
# ================================
# Skopiuj ten plik jako .env i uzupełnij wartości
# cp .env.example .env
# NIGDY nie commituj pliku .env do repozytorium!

# --- PostgreSQL ---
POSTGRES_DB=flashlearn
POSTGRES_USER=flashlearn_user
POSTGRES_PASSWORD=change_me_please

# --- JWT ---
# Wygeneruj bezpieczny sekret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_very_long_random_secret_string
JWT_EXPIRATION_MS=3600000

# --- Seeder (opcjonalnie) ---
# Ustaw na "dev" żeby uruchomić DataSeeder przy starcie aplikacji
# SPRING_PROFILES_ACTIVE=dev
